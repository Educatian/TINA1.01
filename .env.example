# --- Client-side (safe to expose; compiled into the bundle) -----------------
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Server-side ONLY (read by netlify/functions/ai-proxy.mts; never put AI
# --- keys behind a VITE_ prefix in new deployments. VITE_-prefixed values are
# --- still accepted as a server-side fallback so existing Netlify sites keep
# --- working without dashboard edits.)
GEMINI_API_KEY=your_gemini_api_key_here
HF_API_KEY=your_huggingface_api_key_here

# Coaching-move engine flag (defaults on; set 'off' to disable)
# VITE_COACHING_ENGINE=on
