{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:worker",
    "build:worker": "esbuild cloudflare/worker/index.ts --bundle --format=esm --target=es2022 --conditions=worker,browser --external:node:* --outfile=dist/_worker.js",
    "preview": "vite preview",
    "test": "node --test src/services/*.test.mjs",
    "cf:deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "docx": "^9.5.1",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
